# --- Frontend (Vercel / `cd web && npm run dev`) ---
# Base URL of the Rocqet API. Locally this is http://localhost:8000.
# In production, set this to your deployed Railway API URL.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Backend API (only if NOT using the baked Dockerfile.api defaults) ---
# ROCQET_EMBEDDER=local           # hash | local | fastembed | openai (must match how the index was built)
# EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# QDRANT_URL=                     # set to use a remote/managed Qdrant instead of the on-disk store
# QDRANT_API_KEY=                 # managed-Qdrant API key
# ROCQET_COLLECTION=rocqet_declarations   # Qdrant collection name
# OPENAI_API_KEY=                 # only when ROCQET_EMBEDDER=openai
#
# CORS: the API is a public, read-only search service, so it defaults to
# CORS_ORIGINS=*. To restrict browser callers to your own UI, set a
# comma-separated allowlist, e.g. CORS_ORIGINS=https://rocqet.vercel.app
# CORS_ORIGINS=*

# --- MCP server (rocqet-mcp) ---
# ROCQET_API_URL=http://localhost:8000   # the hosted API the MCP server proxies to

# --- Offline indexing only (never needed at serving time) ---
# GEMINI_API_KEY=                 # only for the offline NL-description pass (rocqet-describe)
